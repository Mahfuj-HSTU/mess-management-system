generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Better Auth Required Models ─────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  messMembers      MessMember[]
  monthlyManaging  MonthlyManager[]
  mealsAdded       Meal[]           @relation("MealAddedBy")
  bazaars          Bazaar[]
  paymentsMade     Payment[]        @relation("PaymentAddedBy")
  paymentsReceived Payment[]        @relation("PaymentMember")
  mealConfigsSet   MealConfig[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Mess Management Models ───────────────────────────────────────────────────

model Mess {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         MessMember[]
  monthlyManagers MonthlyManager[]
  meals           Meal[]
  bazaars         Bazaar[]
  payments        Payment[]
  cash            ManagerCash?
  mealConfig      MealConfig?
}

// Only two permanent roles: super admin (created the mess) and regular member
model MessMember {
  id       String     @id @default(cuid())
  messId   String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messId, userId])
}

enum MemberRole {
  SUPER_ADMIN
  MEMBER
}

// Super admin assigns one manager per month. Different months can have different managers.
model MonthlyManager {
  id         String   @id @default(cuid())
  messId     String
  userId     String
  month      Int      // 1–12
  year       Int
  assignedAt DateTime @default(now())

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messId, month, year]) // one manager per month per mess
}

// Manager configures how many meals each type counts as.
// breakfast defaults to 0 (ignored). Manager can enable it with a non-zero value.
model MealConfig {
  id          String   @id @default(cuid())
  messId      String   @unique
  breakfast   Float    @default(0)   // 0 = disabled / not counted
  lunch       Float    @default(1)
  dinner      Float    @default(1)
  updatedById String
  updatedAt   DateTime @updatedAt

  mess      Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  updatedBy User @relation(fields: [updatedById], references: [id])
}

model Meal {
  id         String   @id @default(cuid())
  messId     String
  userId     String
  date       DateTime @db.Date
  breakfast  Boolean  @default(false)
  lunch      Boolean  @default(false)
  dinner     Boolean  @default(false)
  totalMeals  Float    @default(0) // stored at entry time using current MealConfig
  guestMeals  Int      @default(0) // extra meals for guests brought by this member
  addedById   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mess    Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  addedBy User @relation("MealAddedBy", fields: [addedById], references: [id])

  @@unique([messId, userId, date])
}

model Bazaar {
  id          String   @id @default(cuid())
  messId      String
  amount      Float
  description String?
  date        DateTime @db.Date
  addedById   String
  createdAt   DateTime @default(now())

  mess    Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  addedBy User @relation(fields: [addedById], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  messId    String
  memberId  String
  amount    Float
  note      String?
  date      DateTime @db.Date
  addedById String
  createdAt DateTime @default(now())

  mess    Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
  member  User @relation("PaymentMember", fields: [memberId], references: [id])
  addedBy User @relation("PaymentAddedBy", fields: [addedById], references: [id])
}

model ManagerCash {
  id        String   @id @default(cuid())
  messId    String   @unique
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
}
